# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your project dashboard: https://supabase.com
# Settings → API → Project URL & Project API keys (anon / public)

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Netlify variant (also supported by the app)
# VITE_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Web Push Notifications (VAPID) ────────────────────────────────────────────
# Generate your own VAPID key pair with:
#   npx web-push generate-vapid-keys
# Then copy the PUBLIC KEY below (frontend) and set PRIVATE KEY in Supabase Edge Function env vars.
#
# In Supabase Dashboard → Edge Functions → send-budget-push → Secrets:
#   VAPID_SUBJECT    = mailto:you@yoursite.com
#   VAPID_PUBLIC_KEY = (same value as VITE_VAPID_PUBLIC_KEY)
#   VAPID_PRIVATE_KEY= your-private-key-here

VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ── Site URL (for OAuth callbacks) ────────────────────────────────────────────
VITE_SITE_URL=http://localhost:5173
